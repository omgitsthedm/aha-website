# After Hours Agenda — environment example (placeholders only; never commit real values)
# Governing doc: docs/MASTER-BUILD-INSTRUCTION.md §11. Real values live in Netlify env / password manager.
# Local, Deploy Preview, and staging MUST use Square Sandbox + Printful non-live.

# ── Site ─────────────────────────────────────────────────────────────────────
SITE_URL=https://afterhoursagenda.com
PUBLIC_SITE_URL=https://afterhoursagenda.com
NEXT_PUBLIC_SITE_URL=https://afterhoursagenda.com
ORDER_SUPPORT_EMAIL=info@afterhoursagenda.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="After Hours Agenda <orders@afterhoursagenda.com>"
RESEND_REPLY_TO=info@afterhoursagenda.com
NODE_ENV=development

# ── Database (Netlify DB / Neon) ─────────────────────────────────────────────
# Netlify injects NETLIFY_DB_URL at runtime (provisioned via `netlify database init`).
# NETLIFY_DATABASE_URL and DATABASE_URL are legacy/local fallbacks only.
NETLIFY_DB_URL=
NETLIFY_DATABASE_URL=
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Netlify ──────────────────────────────────────────────────────────────────
NETLIFY_SITE_ID=275b4115-16bf-42fb-9b36-6bce9bb93608
NETLIFY_AUTH_TOKEN=your_netlify_auth_token

# ── Square (payments/orders source of truth) ────────────────────────────────
# Use sandbox everywhere except production. Production launch: SQUARE_ENVIRONMENT=production.
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=your_square_app_id
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_NOTIFICATION_URL=https://afterhoursagenda.netlify.app/api/webhooks/square
SQUARE_API_VERSION=2024-01-18
# Public (safe to ship to the browser)
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id

# ── Printful API v2 beta (fulfillment/catalog/shipping source of truth) ──────
PRINTFUL_API_VERSION=v2-beta
PRINTFUL_API_BASE_URL=https://api.printful.com/v2
PRINTFUL_API_TOKEN=your_printful_token
PRINTFUL_STORE_ID=your_printful_store_id
PRINTFUL_WEBHOOK_SECRET=your_printful_webhook_secret_key_hex
PRINTFUL_WEBHOOK_PUBLIC_KEY=your_printful_webhook_public_key
PRINTFUL_DEFAULT_SHIPPING=STANDARD
PRINTFUL_DEFAULT_CURRENCY=USD
PRINTFUL_DEFAULT_SELLING_REGION=north_america
# HARD money-switches: live Printful order confirmation only when BOTH are true (production only).
PRINTFUL_ALLOW_CONFIRM_ORDERS=false
PRINTFUL_LIVE_MODE=false

# ── Internal readiness / fulfillment gates ───────────────────────────────────
AHA_FULFILLMENT_MODE=manual
AHA_READINESS_TOKEN=your_internal_readiness_token

# ── SMS provider (optional; transactional email uses Resend above) ───────────
SMS_PROVIDER=
SMS_PROVIDER_API_KEY=

# ── Analytics (keys TBD) ─────────────────────────────────────────────────────
ANALYTICS_PROVIDER=
ANALYTICS_WRITE_KEY=
META_PIXEL_ID=
TIKTOK_PIXEL_ID=
GOOGLE_MERCHANT_CENTER_ID=

# Web Push (order-shipped alerts). Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@afterhoursagenda.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
