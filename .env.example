# Square API
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_app_id
SQUARE_ENVIRONMENT=production
SQUARE_API_VERSION=2024-01-18
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_NOTIFICATION_URL=https://www.afterhoursagenda.com/api/webhooks/square

# Printful API
PRINTFUL_API_TOKEN=your_printful_token
PRINTFUL_STORE_ID=your_printful_store_id
PRINTFUL_WEBHOOK_SECRET_KEY=your_printful_webhook_secret_key_hex
PRINTFUL_WEBHOOK_PUBLIC_KEY=your_printful_webhook_public_key

# Public
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Internal readiness / fulfillment gates
AHA_FULFILLMENT_MODE=manual
AHA_READINESS_TOKEN=your_internal_readiness_token
